# SOC Sentinel — Splunk config. Copy to .env (gitignored) and fill in real values.

# --- Splunk instance (management/API port) ---
SPLUNK_HOST=https://localhost:8089
SPLUNK_USER=admin
SPLUNK_PASSWORD=changeme            # your local admin password; never commit the real one

# --- Splunk MCP Server (fill in AFTER Step 5) ---
SPLUNK_MCP_URL=                     # e.g. http://localhost:PORT  or  stdio command
SPLUNK_MCP_TRANSPORT=               # http | sse | stdio  (whatever the server uses)
SPLUNK_MCP_TOKEN=                   # if it needs a token
